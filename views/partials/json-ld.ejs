<% if (typeof baseUrl !== 'undefined' && baseUrl) { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "<%= baseUrl %>/#localbusiness",
      "name": "Mohaa Finest Curtains",
      "alternateName": "Mohaa Finest Curtains Nairobi",
      "slogan": "Think Curtains. Think Mohaa.",
      "description": "Mohaa Finest Curtains is the curtain dealer in Eastleigh, Nairobi, known for quality curtains, free measurement and professional installation. We sell sheer, blackout and custom quality curtains and serve Nairobi, Eastleigh and Kenya from Moyale Mall, Shop S26.",
      "url": "<%= baseUrl %>",
      "telephone": "+<%= phoneIntl %>",
      "email": "info@mohaafinestcurtains.co.ke",
      "image": "<%= typeof ogImage !== 'undefined' ? ogImage : baseUrl + '/images/logo.jpeg' %>",
      "logo": "<%= baseUrl %>/images/logo.jpeg",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Moyale Mall, Shop S26, 1st Avenue, 4th Street, Eastleigh",
        "addressLocality": "Eastleigh",
        "addressRegion": "Nairobi",
        "addressCountry": "KE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -1.2767,
        "longitude": 36.8219
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "10:00", "closes": "18:00" }
      ],
      "areaServed": [
        { "@type": "Country", "name": "Kenya" },
        { "@type": "City", "name": "Nairobi" },
        { "@type": "Place", "name": "Eastleigh", "address": { "@type": "PostalAddress", "addressLocality": "Eastleigh", "addressRegion": "Nairobi" } },
        { "@type": "State", "name": "Nairobi County" }
      ],
      "sameAs": [],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Curtain products and services in Nairobi",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Curtain sales - sheer, blackout, luxury" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Custom curtain designs Nairobi" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Free measurement and site visits Nairobi & Eastleigh" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Professional curtain installation Nairobi" } }
        ]
      }
    },
    {
      "@type": "Organization",
      "@id": "<%= baseUrl %>/#organization",
      "name": "Mohaa Finest Curtains",
      "url": "<%= baseUrl %>",
      "logo": "<%= baseUrl %>/images/logo.jpeg"
    },
    {
      "@type": "WebSite",
      "@id": "<%= baseUrl %>/#website",
      "url": "<%= baseUrl %>",
      "name": "Mohaa Finest Curtains - Quality Curtains Nairobi | Curtain Dealer Eastleigh",
      "description": "Mohaa Finest Curtains is the curtain dealer in Eastleigh, Nairobi. Quality curtains, free measurement, professional installation.",
      "publisher": { "@id": "<%= baseUrl %>/#organization" }
    }
  ]
}
</script>
<% } %>
