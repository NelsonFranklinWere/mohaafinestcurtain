<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    <meta name="keywords" content="<%= typeof keywords !== 'undefined' ? keywords : 'curtains Nairobi FAQ, curtain shop Eastleigh, quality curtains Kenya' %>">
    <meta name="author" content="Mohaa Finest Curtains">
    <meta name="robots" content="index, follow">
    <meta name="geo.region" content="KE-30">
    <meta name="geo.placename" content="Eastleigh, Nairobi">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= canonicalUrl %>">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= description %>">
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:site_name" content="Mohaa Finest Curtains">
    <meta property="og:locale" content="en_KE">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/images/logo.jpeg" type="image/jpeg">
    <%- include('partials/json-ld') %>
    <!-- AEO/GEO: FAQPage schema for voice & AI answers -->
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Where can I buy quality curtains in Eastleigh, Nairobi?", "acceptedAnswer": { "@type": "Answer", "text": "Mohaa Finest Curtains is the curtain dealer in Eastleigh, Nairobi. You can buy quality curtains at our showroom at Moyale Mall, Shop S26, 1st Avenue, 4th Street, Eastleigh, or contact us on WhatsApp for free measurement and quotes." }},
    { "@type": "Question", "name": "Who is the curtain dealer in Eastleigh?", "acceptedAnswer": { "@type": "Answer", "text": "Mohaa Finest Curtains is the curtain dealer in Eastleigh, Nairobi. We sell quality curtains, offer free measurement and professional installation. Visit Moyale Mall, Eastleigh or WhatsApp us." }},
    { "@type": "Question", "name": "Does Mohaa Finest Curtains offer free curtain measurement in Nairobi?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Mohaa Finest Curtains offers free expert measurement at your location in Nairobi and Eastleigh. Contact us via WhatsApp or phone to book a free site visit." }},
    { "@type": "Question", "name": "What types of quality curtains does Mohaa Finest Curtains sell?", "acceptedAnswer": { "@type": "Answer", "text": "We sell sheer curtains, blackout curtains, luxury and decorative curtains, and custom designs. All our curtains are quality fabrics, professionally measured and installed in Nairobi and Eastleigh." }},
    { "@type": "Question", "name": "Where is Mohaa Finest Curtains located in Nairobi?", "acceptedAnswer": { "@type": "Answer", "text": "Mohaa Finest Curtains is located at Moyale Mall, Shop S26, 1st Avenue, 4th Street, Eastleigh, Nairobi, Kenya. We serve Nairobi, Eastleigh and nationwide." }},
    { "@type": "Question", "name": "How do I order curtains from Mohaa Finest Curtains?", "acceptedAnswer": { "@type": "Answer", "text": "WhatsApp or call us to book a free measurement. We visit your location, you choose fabric and design, then we make and install your quality curtains. Typical timeline is 3–7 days from measurement to installation." }}
  ]
}
    </script>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <img src="/images/logo.jpeg" alt="Mohaa Finest Curtains Logo" class="logo">
                <span class="brand-name">Mohaa Finest Curtains</span>
            </div>
            <div class="nav-menu">
                <a href="/" class="nav-link">Home</a>
                <a href="/collections" class="nav-link">Collections</a>
                <a href="/services" class="nav-link">Services</a>
                <a href="/about" class="nav-link">About</a>
                <a href="/blog" class="nav-link">Curtain Tips</a>
                <a href="/how-it-works" class="nav-link">How It Works</a>
                <a href="/gallery" class="nav-link">Gallery</a>
                <a href="/faq" class="nav-link <%= currentPage === 'faq' ? 'active' : '' %>">FAQ</a>
                <a href="/contact" class="nav-link">Contact</a>
            </div>
            <div class="mobile-menu-toggle" aria-label="Menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <main>
        <section class="page-hero">
            <div class="container">
                <h1>Frequently Asked Questions</h1>
                <p>Quality curtains in Nairobi & Eastleigh — your questions answered.</p>
            </div>
        </section>

        <section class="faq-section">
            <div class="container">
                <p class="faq-intro">Mohaa Finest Curtains is the curtain dealer in Eastleigh, Nairobi, known for quality curtains, free measurement and professional installation. Below are answers to common questions.</p>

                <div class="faq-list">
                    <div class="faq-item">
                        <h2 class="faq-q">Where can I buy quality curtains in Eastleigh, Nairobi?</h2>
                        <div class="faq-a"><p>Mohaa Finest Curtains is the curtain dealer in Eastleigh, Nairobi. You can buy quality curtains at our showroom at <strong>Moyale Mall, Shop S26, 1st Avenue, 4th Street, Eastleigh</strong>, or contact us on WhatsApp for free measurement and quotes.</p></div>
                    </div>
                    <div class="faq-item">
                        <h2 class="faq-q">Who is the curtain dealer in Eastleigh?</h2>
                        <div class="faq-a"><p>Mohaa Finest Curtains is the curtain dealer in Eastleigh, Nairobi. We sell quality curtains, offer free measurement and professional installation. Visit Moyale Mall, Eastleigh or WhatsApp us.</p></div>
                    </div>
                    <div class="faq-item">
                        <h2 class="faq-q">Does Mohaa Finest Curtains offer free curtain measurement in Nairobi?</h2>
                        <div class="faq-a"><p>Yes. We offer free expert measurement at your location in Nairobi and Eastleigh. Contact us via WhatsApp or phone to book a free site visit.</p></div>
                    </div>
                    <div class="faq-item">
                        <h2 class="faq-q">What types of quality curtains do you sell?</h2>
                        <div class="faq-a"><p>We sell sheer curtains, blackout curtains, luxury and decorative curtains, and custom designs. All our curtains are quality fabrics, professionally measured and installed in Nairobi and Eastleigh.</p></div>
                    </div>
                    <div class="faq-item">
                        <h2 class="faq-q">Where is Mohaa Finest Curtains located in Nairobi?</h2>
                        <div class="faq-a"><p>We are at <strong>Moyale Mall, Shop S26, 1st Avenue, 4th Street, Eastleigh, Nairobi, Kenya</strong>. We serve Nairobi, Eastleigh and nationwide.</p></div>
                    </div>
                    <div class="faq-item">
                        <h2 class="faq-q">How do I order curtains from Mohaa Finest Curtains?</h2>
                        <div class="faq-a"><p>WhatsApp or call us to book a free measurement. We visit your location, you choose fabric and design, then we make and install your quality curtains. Typical timeline is 3–7 days from measurement to installation.</p></div>
                    </div>
                </div>

                <div class="faq-cta">
                    <a href="https://wa.me/<%= phoneIntl %>?text=Hi%20Mohaa%20Finest%20Curtains,%20I%20have%20a%20question%20about%20curtains" class="btn btn-primary" target="_blank">Ask on WhatsApp</a>
                    <a href="/contact" class="btn btn-secondary">Contact Us</a>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Mohaa Finest Curtains</h3>
                    <p>Quality curtains in Nairobi & Eastleigh. Think Curtains. Think Mohaa.</p>
                </div>
                <div class="footer-section">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="/faq">FAQ</a></li>
                        <li><a href="/services">Services</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <p>📞 <%= phone %> | 💬 <a href="https://wa.me/<%= phoneIntl %>" target="_blank">WhatsApp</a></p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; <%= new Date().getFullYear() %> Mohaa Finest Curtains. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <a href="https://wa.me/<%= phoneIntl %>?text=Hi%20Mohaa%20Finest%20Curtains,%20I%20need%20quality%20curtains" class="whatsapp-sticky" target="_blank" aria-label="WhatsApp">💬 WhatsApp</a>

    <script src="/js/script.js"></script>
    <style>
.faq-section { padding: 40px 0 60px; }
.faq-intro { max-width: 720px; margin-bottom: 2rem; font-size: 1.05rem; color: var(--text-grey); }
.faq-list { display: flex; flex-direction: column; gap: 1.5rem; }
.faq-item { border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; }
.faq-q { font-size: 1.1rem; margin: 0; padding: 1rem 1.25rem; background: var(--light-grey); color: var(--primary-teal); }
.faq-a { padding: 1rem 1.25rem; }
.faq-a p { margin: 0; }
.faq-cta { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2.5rem; }
@media (max-width: 480px) {
    .faq-section { padding: 24px 0 40px; }
    .faq-q { font-size: 1rem; padding: 0.875rem 1rem; }
    .faq-a { padding: 0.875rem 1rem; }
    .faq-cta .btn { min-height: 48px; width: 100%; }
}
    </style>
</body>
</html>
